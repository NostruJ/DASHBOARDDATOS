{
  "builds": [
    {
      "src": "dashboard-api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "dashboard-ui/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dashboard-api/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "dashboard-ui/dist/$1"
    }
  ]
}
